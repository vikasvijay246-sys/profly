# Copy to .env and edit before running
SECRET_KEY=change-this-to-a-long-random-string-in-production

# SQLite (default, no extra setup needed)
DATABASE_URL=sqlite:///propflow.db

# PostgreSQL (uncomment and edit to use Postgres instead)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/propflow

# Upload settings
MAX_CONTENT_LENGTH_MB=50
UPLOAD_FOLDER=static/uploads

# Admin seed credentials (used on first run only)
ADMIN_PHONE=admin
ADMIN_PASSWORD=admin123
